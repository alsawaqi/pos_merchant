APP_NAME="MITHQAL Merchant Portal"
APP_ENV=local
# CRITICAL — must match pos_admin's APP_KEY exactly.
# pos_admin encrypts PII (phone, civil_id) on the shared
# pos_users table with this key; if pos_merchant has a
# different key, every read of an encrypted column fails
# with "The MAC is invalid." Copy pos_admin's APP_KEY here
# verbatim, do NOT run `artisan key:generate` standalone.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8087

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=chariyt-db
DB_PORT=5432
DB_DATABASE=charity_db
DB_USERNAME=charity_user
DB_PASSWORD=super_secret_password
# Each Laravel app inside charity_db keeps its own migrations table so
# pos_merchant can migrate/rollback independently of pos_admin and the
# charity app that own the rest of this database.
DB_MIGRATIONS_TABLE=pos_merchant_migrations

# Sliding session: portal users get logged out after N minutes of
# inactivity. JWT TTL bounds how long an issued token is honoured
# even when the session is still warm.
POS_MERCHANT_IDLE_TIMEOUT_MINUTES=30
POS_MERCHANT_JWT_TTL_MINUTES=60
POS_MERCHANT_LOGIN_RATE_LIMIT_PER_MINUTE=5

# Session, queue, cache, password_reset_tokens and personal_access_tokens
# all reuse the charity DB's existing default-named tables. We only
# override the session COOKIE name so charity, pos_admin, and pos_merchant
# can hold independent sessions on the same host. PREFIX is set on the
# redis/cache key namespace to keep our cache entries from colliding.
SESSION_DRIVER=redis
SESSION_COOKIE=pos_merchant_web_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=pos_merchant_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Must match the unique service name in docker-compose.yml. The shared
# charity_net hosts pos_admin's `pos_admin_redis` service too; using the
# generic name would round-robin DNS between them and split sessions
# across two Redis instances.
REDIS_HOST=pos_merchant_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sentry — leave empty in local dev to disable; set to the project DSN
# in staging + production. Helpers in lib/sentry.ts and config/sentry.php
# (when published) become no-ops without a DSN.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8087
# VITE_PORT is the bind port INSIDE the container — matches the right-hand
# side of the `vite` service's `5174:5174` mapping in docker-compose. The
# pos_admin project sits on host port 5175.
VITE_PORT=5174
# VITE_DEV_SERVER_URL and VITE_HMR_PORT are the HOST-facing values — what
# your browser sees. Must equal the LEFT side of the compose mapping.
VITE_DEV_SERVER_URL=http://localhost:5174
VITE_DEV_SERVER_CORS_ORIGINS=http://localhost:8087,http://127.0.0.1:8087
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5174
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# P-G6 - pos_api's Reverb server (device live nudges; same app creds as
# pos_api, host = the reverb container on charity_net). Unset = no-op.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
