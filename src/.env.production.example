# =============================================================================
# pos_merchant — PRODUCTION .env template  (posmerchant.mithqal.net)
# Copy to `src/.env` on the VPS and fill the secrets (APP_KEY, DB_PASSWORD).
#   cp src/.env.production.example src/.env
# =============================================================================

APP_NAME="MITHQAL Merchant Portal"
APP_ENV=production
# CRITICAL — paste pos_admin's APP_KEY here VERBATIM. The two apps share the
# encrypted pos_users PII on charity_db; a different key => "MAC is invalid"
# on every encrypted read. Do NOT run `key:generate` for pos_merchant.
APP_KEY=
APP_DEBUG=false
APP_URL=https://posmerchant.mithqal.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Shared charity Postgres (charity_db) on charity_net --------------------
DB_CONNECTION=pgsql
DB_HOST=chariyt-db
DB_PORT=5432
DB_DATABASE=charity_db
DB_USERNAME=charity_user
DB_PASSWORD=
# pos_merchant owns NO production schema (pos_admin owns the pos_* tables).
# Its only migration is a testing-only fixture, guarded to no-op in prod.
# Do NOT run `php artisan migrate` against the production DB from pos_merchant.
DB_MIGRATIONS_TABLE=pos_merchant_migrations

POS_MERCHANT_IDLE_TIMEOUT_MINUTES=30
POS_MERCHANT_JWT_TTL_MINUTES=60
POS_MERCHANT_LOGIN_RATE_LIMIT_PER_MINUTE=5

# ---- Sessions / cache / queue (Redis) --------------------------------------
SESSION_DRIVER=redis
SESSION_COOKIE=pos_merchant_web_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=pos_merchant_cache

REDIS_CLIENT=phpredis
# Matches the unique redis service name in docker-compose.prod.yml.
REDIS_HOST=pos_merchant_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@mithqal.net"
MAIL_FROM_NAME="${APP_NAME}"

# Sentry (optional)
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Front-end build (Vite) ------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=https://posmerchant.mithqal.net
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
